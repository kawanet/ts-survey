{
  "exclude": [
    "node_modules"
  ],
  "include": [
    "src/",
    "sample/"
  ],
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "module": "ES2022",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noImplicitAny": true,
    "types": [
      "node"
    ],
    "noImplicitReturns": false,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "removeComments": false,
    "resolveJsonModule": true,
    "skipLibCheck": false,
    "sourceMap": false,
    "strictNullChecks": false,
    "target": "ES2022"
  }
}
